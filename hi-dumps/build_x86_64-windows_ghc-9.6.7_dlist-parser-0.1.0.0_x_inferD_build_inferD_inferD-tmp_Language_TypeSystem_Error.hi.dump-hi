  type InferError :: *
  data InferError
    = UnboundVariable Language.TypeSystem.BaseType.Name
    | UnificationFail Language.TypeSystem.Syntax.Type
                      Language.TypeSystem.Syntax.Type
    | UnificationMismatch Language.TypeSystem.Syntax.Type
                          Language.TypeSystem.Syntax.Type
    | InfiniteType Language.TypeSystem.Syntax.TVar
                   Language.TypeSystem.Syntax.Type
    | Ambiguous [Language.TypeSystem.Syntax.Pred]
    | UnificationError GHC.Base.String
    | OtherError GHC.Base.String
