  type Binding :: *
  type Binding = (AST.Pattern.Pattern, Expr)
44ea8c3557f503075c2a19306f8a550b
  type CaseAlt :: *
  data CaseAlt
    = CaseAlt AST.Pattern.Pattern Expr
    | CaseAltGuard AST.Pattern.Pattern [(Expr, Expr)]
67d1914a4d80f370ba8adab5470db0aa
  type EDecl :: *
  data EDecl
    = EDeclFun AST.Type.Name [AST.Pattern.Pattern] Expr
    | EDeclTypeSig AST.Type.Name AST.Type.Type
2034d0c66391aa26000e1203f1d4bd4d
  type Expr :: *
  data Expr
    = EVar GHC.Base.String
    | EVarType GHC.Base.String
    | EInt GHC.Types.Int
    | EString GHC.Base.String
    | EChar GHC.Types.Char
    | EBinOp AST.BinOp.BinOp Expr Expr
    | EBool GHC.Types.Bool
    | ELet AST.Pattern.Pattern Expr Expr
    | ELetBlock [(AST.Pattern.Pattern, Expr)] Expr
    | EIf Expr Expr Expr
    | ELam [AST.Pattern.Pattern] Expr
    | EApp Expr Expr
    | ECase Expr [CaseAlt]
    | EList [Expr]
    | ETuple [Expr]
    | ERecordConstr AST.Type.Name [(AST.Type.Name, Expr)]
    | EFieldAccess Expr GHC.Base.String
    | ERange Expr (GHC.Maybe.Maybe Expr)
    | ERangeStep Expr Expr (GHC.Maybe.Maybe Expr)
    | EListComp Expr [Qualifier]
    | EAnn Expr AST.Type.Type
    | EDo [Stmt]
    | ESeq [Expr]
    | EReturn Expr
    | EUnit
    | ERecord [(GHC.Base.String, Expr)]
    | ERecordUpdate Expr [(GHC.Base.String, Expr)]
    | EOpSectionL AST.BinOp.BinOp Expr
    | EOpSectionR Expr AST.BinOp.BinOp
    | EPlaceholder
    | EWhere Expr [Binding]
    | ELambdaCase [CaseAlt]
    | ESQL GHC.Base.String [Expr]
fcb3eb15d1f5ff43eca0c824a9cee103
  type Qualifier :: *
  data Qualifier
    = QGenerator AST.Pattern.Pattern Expr
    | QLet [(AST.Pattern.Pattern, Expr)]
    | QGuard Expr
