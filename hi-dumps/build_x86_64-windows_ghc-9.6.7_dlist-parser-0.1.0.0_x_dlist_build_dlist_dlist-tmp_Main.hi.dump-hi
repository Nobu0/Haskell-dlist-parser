  runParserWithTrace1 ::
    Parser.Core.Combinator.Parser a
    -> [Lexer.Token.Token]
    -> GHC.Prim.State# GHC.Prim.RealWorld
    -> (# GHC.Prim.State# GHC.Prim.RealWorld, GHC.Maybe.Maybe a #)
  [TagSig: <TagTuple[TagProper]>, LambdaFormInfo: LFReEntrant 3,
   Arity: 3,
   Unfolding: Core: <vanilla>
              \ @a
                (p['GHC.Types.Many] :: Parser.Core.Combinator.Parser a)
                (tokens['GHC.Types.Many] :: [Lexer.Token.Token])
                (s['GHC.Types.Many] :: GHC.Prim.State# GHC.Prim.RealWorld) ->
              case Utils.MyTrace.traceEnabled
                     `cast`
                   (GHC.IORef.N:IORef[0] <GHC.Types.Bool>_N) of wild { GHC.STRef.STRef var# ->
              case GHC.Prim.writeMutVar#
                     @'GHC.Types.Lifted
                     @GHC.Prim.RealWorld
                     @GHC.Types.Bool
                     var#
                     GHC.Types.False
                     s of s2# { DEFAULT ->
              let {
                fail :: (# #)
                        -> (# GHC.Prim.State# GHC.Prim.RealWorld, GHC.Maybe.Maybe a #)
                  <join 1> [Arity: 1, Strictness: <L>]
                = \ (ds['GHC.Types.Many] :: (# #))[OneShot] ->
                  case GHC.IO.Handle.Text.hPutStr2
                         GHC.IO.StdHandles.stdout
                         (GHC.CString.unpackCString#
                            "XX Parser failed! Re-running with trace:"#)
                         GHC.Types.True
                         s2# of ds1 { (#,#) ipv ipv1 ->
                  case GHC.Prim.writeMutVar#
                         @'GHC.Types.Lifted
                         @GHC.Prim.RealWorld
                         @GHC.Types.Bool
                         var#
                         GHC.Types.True
                         ipv of s2#1 { DEFAULT ->
                  case p `cast` (Parser.Core.Combinator.N:Parser[0] <a>_R)
                         tokens of wild1 {
                    GHC.Maybe.Nothing -> (# s2#1, GHC.Maybe.Nothing @a #)
                    GHC.Maybe.Just ds2
                    -> case ds2 of wild2 { (,) result ds3 ->
                       case ds3 of wild3 {
                         [] -> (# s2#1, GHC.Maybe.Just @a result #)
                         : ipv2 ipv3 -> (# s2#1, GHC.Maybe.Nothing @a #) } } } } }
              } in
              case p `cast` (Parser.Core.Combinator.N:Parser[0] <a>_R)
                     tokens of wild1 {
                GHC.Maybe.Nothing -> fail GHC.Prim.(##)
                GHC.Maybe.Just ds
                -> case ds of wild2 { (,) result ds1 ->
                   case ds1 of wild3 {
                     [] -> (# s2#, GHC.Maybe.Just @a result #)
                     : ipv ipv1 -> fail GHC.Prim.(##) } } } } }]
