                     GHC.Maybe.Just scheme
                     -> case Language.TypeSystem.InferInstances.$fSchemeLikeScheme1
                               scheme
                               s'
                               ipv of ds2 { (#,#) ipv2 ipv3 ->
                        case ipv3 of wild3 { (,) a2 s'1 ->
                        case a2 of wild4 {
                          Data.Either.Left e1
                          -> (# ipv2,
                                (Data.Either.Left
                                   @Language.TypeSystem.Error.InferError
                                   @(Language.TypeSystem.Syntax.Subst,
                                     Language.TypeSystem.Env.TypeEnv,
                                     Language.TypeSystem.Syntax.Type)
                                   e1,
                                 s'1) #)
                          Data.Either.Right x1
                          -> case x1 of wild5 { (,) t ds ->
                             inferConstrApp1 t args s'1 ipv2 } } } } } } } }]
