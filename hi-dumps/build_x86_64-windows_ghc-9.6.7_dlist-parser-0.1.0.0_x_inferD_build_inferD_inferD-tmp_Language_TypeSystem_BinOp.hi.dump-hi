  type BinOp :: *
  data BinOp
    = Add
    | Sub
    | Mul
    | Div
    | Eq
    | Neq
    | Lt
    | Gt
    | Le
    | Ge
    | And
    | Or
    | Concat
    | Cons
    | Compose
    | Then
    | Bind
    | Alt
    | Fmap
    | App
