  prettyScheme :: TypeInference.TypeEnv.Scheme -> GHC.Base.String
  [LambdaFormInfo: LFReEntrant 1, Arity: 1,
   Unfolding: Core: <vanilla>
              \ (ds['GHC.Types.Many] :: TypeInference.TypeEnv.Scheme) ->
              case ds of wild { TypeInference.TypeEnv.Forall ds1 ty ->
              case ds1 of wild1 {
                [] -> prettyType ty
                : ipv ipv1
                -> GHC.Base.++
                     @GHC.Types.Char
