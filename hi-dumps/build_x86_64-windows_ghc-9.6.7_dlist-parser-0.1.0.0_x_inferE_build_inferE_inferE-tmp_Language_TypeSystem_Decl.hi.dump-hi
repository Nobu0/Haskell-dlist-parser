  type Decl :: *
  data Decl
    = DeclFunGroup Language.TypeSystem.BaseType.Name [FunClause]
    | DeclValue Language.TypeSystem.Pattern.Pattern
                Language.TypeSystem.Expr.Expr
    | DeclTypeSig Language.TypeSystem.BaseType.Name
                  Language.TypeSystem.Syntax.Scheme
    | DeclData Language.TypeSystem.BaseType.Name
               [Language.TypeSystem.BaseType.Name]
               [Language.TypeSystem.Syntax.Constraint]
               [Language.TypeSystem.BaseType.Name]
    | DeclNewtype Language.TypeSystem.BaseType.Name
                  [Language.TypeSystem.BaseType.Name]
                  Language.TypeSystem.Syntax.Constraint
                  (GHC.Maybe.Maybe [Language.TypeSystem.BaseType.Name])
    | DeclModule GHC.Base.String (GHC.Maybe.Maybe [Export])
    | DeclClass GHC.Base.String [GHC.Base.String] [Decl]
    | DeclInstance (GHC.Maybe.Maybe
                      [Language.TypeSystem.Syntax.Constraint])
                   GHC.Base.String
                   [Language.TypeSystem.Syntax.Type]
                   [Decl]
    | DeclTypeAlias GHC.Base.String
                    [GHC.Base.String]
                    Language.TypeSystem.Syntax.Type
    | DeclImport {importQualified :: GHC.Types.Bool,
                  importModule :: Language.TypeSystem.BaseType.Name,
                  importAlias :: GHC.Maybe.Maybe Language.TypeSystem.BaseType.Name,
                  importHiding :: GHC.Types.Bool,
                  importItems :: GHC.Maybe.Maybe [ImportItem]}
e345e247012a76fd5324cca1a1791c54
  type Export :: *
  data Export
    = ExportVar GHC.Base.String
    | ExportType GHC.Base.String GHC.Types.Bool
04cb215eceac5a784f80e0b7800baca0
  type FunClause :: *
  data FunClause
    = FunClause [Language.TypeSystem.Pattern.Pattern]
                (GHC.Maybe.Maybe
                   [(Language.TypeSystem.Expr.Expr, Language.TypeSystem.Expr.Expr)])
                (GHC.Maybe.Maybe Language.TypeSystem.Expr.Expr)
                (GHC.Maybe.Maybe [Decl])
62c725cc81aa889528719d64f2f17da1
  type ImportItem :: *
  data ImportItem
    = ImportVar Language.TypeSystem.BaseType.Name
    | ImportTypeAll Language.TypeSystem.BaseType.Name
    | ImportTypeSome Language.TypeSystem.BaseType.Name
                     [Language.TypeSystem.BaseType.Name]
    | ImportAllItems
