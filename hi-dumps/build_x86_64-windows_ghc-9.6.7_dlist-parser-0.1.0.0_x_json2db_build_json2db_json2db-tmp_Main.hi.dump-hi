  main1 ::
    GHC.Prim.State# GHC.Prim.RealWorld
    -> (# GHC.Prim.State# GHC.Prim.RealWorld, () #)
  [LambdaFormInfo: LFReEntrant 1, Arity: 1,
   Unfolding: Core: <vanilla>
              \ (s['GHC.Types.Many] :: GHC.Prim.State# GHC.Prim.RealWorld) ->
              case Data.ByteString.Lazy.readFile1
                     (GHC.CString.unpackCString# "inferDB5.json"#)
                     s of ds1 { (#,#) ipv ipv1 ->
              case Data.Aeson.Decoding.eitherDecode
                     @[Language.Tool.Type.TypeDBJson]
                     main2
                     ipv1 of wild {
                Data.Either.Left err
                -> GHC.IO.Handle.Text.hPutStr2
                     GHC.IO.StdHandles.stdout
                     (GHC.Base.++
                        @GHC.Types.Char
                        (GHC.CString.unpackCString# "X JSON parse error: "#)
                        err)
                     GHC.Types.True
                     ipv
                Data.Either.Right modules
                -> GHC.IO.Handle.Text.hPutStr2
                     GHC.IO.StdHandles.stdout
                     (Language.TypeSystem.TypeDB.$fShowTypeDB_$cshowsPrec
                        (GHC.Types.I# 0#)
                        (Language.Tool.Load.buildTypeDB
                           (GHC.Base.map
                              @Language.Tool.Type.TypeDBJson
                              @Language.Tool.Type.TypeDBJson
                              mergeTypes
                              modules))
                        (GHC.Types.[] @GHC.Types.Char))
                     GHC.Types.True
                     ipv } }]
