  findMainModule ::
    Language.TypeSystem.TypeDB.TypeDB
    -> GHC.Maybe.Maybe Language.TypeSystem.BaseType.ModuleName
  [HasNoCafRefs, TagSig: <TagProper>, LambdaFormInfo: LFReEntrant 1,
   Arity: 1,
   Unfolding: Core: <vanilla>
              \ (db['GHC.Types.Many] :: Language.TypeSystem.TypeDB.TypeDB) ->
              letrec {
                ds :: [((Language.TypeSystem.BaseType.ModuleName,
                         Language.TypeSystem.BaseType.Name),
                        Language.TypeSystem.Syntax.Scheme)]
                      -> [Language.TypeSystem.BaseType.ModuleName]
                  [Arity: 1]
                = \ (ds1['GHC.Types.Many] :: [((Language.TypeSystem.BaseType.ModuleName,
                                                Language.TypeSystem.BaseType.Name),
                                               Language.TypeSystem.Syntax.Scheme)]) ->
                  case ds1 of ds2 {
                    [] -> GHC.Types.[] @Language.TypeSystem.BaseType.ModuleName
                    : ds3 ds4
                    -> case ds3 of wild { (,) ds5 ds6 ->
                       case ds5 of wild1 { (,) modName name ->
                       case GHC.Classes.$fEqList_$c==
                              @GHC.Types.Char
                              GHC.Classes.$fEqChar
                              name
                              (GHC.CString.unpackCString# "main"#) of wild2 {
                         GHC.Types.False -> ds ds4
                         GHC.Types.True
                         -> GHC.Types.:
                              @Language.TypeSystem.BaseType.ModuleName
                              modName
                              (ds ds4) } } } }
              } in
              case ds
                     (case db of wild { Language.TypeSystem.TypeDB.TypeDB ds1 ds2 ->
                      Data.Map.Internal.toAscList
                        @(Language.TypeSystem.BaseType.ModuleName,
                          Language.TypeSystem.BaseType.Name)
                        @Language.TypeSystem.Syntax.Scheme
                        ds1 }) of wild {
                [] -> GHC.Maybe.Nothing @Language.TypeSystem.BaseType.ModuleName
                : m ds1
                -> GHC.Maybe.Just @Language.TypeSystem.BaseType.ModuleName m }]
