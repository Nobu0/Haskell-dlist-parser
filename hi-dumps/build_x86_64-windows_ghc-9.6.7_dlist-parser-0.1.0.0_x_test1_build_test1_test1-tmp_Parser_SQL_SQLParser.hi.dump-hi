  parseSQL1 ::
    [Lexer.Token.Token]
    -> GHC.Maybe.Maybe (AST.Expr.Expr, [Lexer.Token.Token])
  [TagSig: <TagProper>, LambdaFormInfo: LFReEntrant 1, Arity: 1,
   Unfolding: Core: <vanilla>
              \ (input['GHC.Types.Many] :: [Lexer.Token.Token]) ->
              case input of wild {
                [] -> GHC.Maybe.Nothing @(AST.Expr.Expr, [Lexer.Token.Token])
                : t ts
                -> case t of wild1 {
                     DEFAULT -> GHC.Maybe.Nothing @(AST.Expr.Expr, [Lexer.Token.Token])
                     Lexer.Token.TokKeyword ds
                     -> case GHC.Classes.$fEqList_$c==
                               @GHC.Types.Char
                               GHC.Classes.$fEqChar
                               ds
                               parseSQL_kw of wild2 {
                          GHC.Types.False
                          -> GHC.Maybe.Nothing @(AST.Expr.Expr, [Lexer.Token.Token])
                          GHC.Types.True
                          -> case ts of wild4 {
                               [] -> GHC.Maybe.Nothing @(AST.Expr.Expr, [Lexer.Token.Token])
                               : t1 ts'
                               -> case t1 of wild5 {
                                    DEFAULT
                                    -> GHC.Maybe.Nothing @(AST.Expr.Expr, [Lexer.Token.Token])
                                    Lexer.Token.TokString s
                                    -> let {
                                         ds1 :: (GHC.Base.String, [GHC.Base.String]) []
                                         = Utils.SQLUtils.extractSQLVars_go
                                             (GHC.Types.[] @GHC.Types.Char)
                                             (GHC.Types.[] @[GHC.Types.Char])
                                             s
                                       } in
                                       GHC.Maybe.Just
                                         @(AST.Expr.Expr, [Lexer.Token.Token])
                                         (AST.Expr.ESQL
                                            (case ds1 of wild6 { (,) sqlBody vars -> sqlBody })
                                            (case ds1 of wild6 { (,) sqlBody vars ->
                                             GHC.Base.map
                                               @GHC.Base.String
                                               @AST.Expr.Expr
                                               (\ (ds2['GHC.Types.Many] :: GHC.Base.String) ->
                                                AST.Expr.EVar ds2)
                                               vars }),
                                          ts') } } } } }]
